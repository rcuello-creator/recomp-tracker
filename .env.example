# Copia este archivo a .env.local y completa los valores
# .env.local está en .gitignore, nunca se commitea

# URL del Apps Script Web App (deployment URL)
VITE_API_URL=https://script.google.com/macros/s/PASTE_DEPLOYMENT_ID_HERE/exec

# Shared secret (32 chars, debe coincidir con SECRET en Code.gs)
VITE_API_SECRET=CHANGE_ME_32_CHARS_RANDOM_STRING
